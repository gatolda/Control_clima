# udev rule: stable symlink for the Arduino Nano (CH340) reading soil moisture.
# Without this, /dev/ttyUSB0 changes on every reconnect.
# Install to: /etc/udev/rules.d/99-arduino-soil.rules
# After install: sudo udevadm control --reload-rules && sudo udevadm trigger

SUBSYSTEM=="tty", ATTRS{idVendor}=="1a86", ATTRS{idProduct}=="7523", SYMLINK+="arduino-soil", MODE="0666", GROUP="dialout"
