[Unit]
Description=Greenhouse daily photo capture
After=network.target

[Service]
Type=oneshot
User=kowen
Group=kowen
WorkingDirectory=/home/kowen/proyectos/Control_clima
EnvironmentFile=-/home/kowen/proyectos/Control_clima/.env
ExecStart=/usr/bin/python3 /home/kowen/proyectos/Control_clima/bin/daily-photo.py
SupplementaryGroups=video

StandardOutput=append:/var/log/greenhouse-photo.log
StandardError=append:/var/log/greenhouse-photo.log
