# logrotate config para todos los logs de greenhouse.
# Wildcard cubre logs futuros sin tener que editar este archivo.
# Runs daily via /etc/cron.daily/logrotate (timer del sistema).

/var/log/greenhouse*.log {
    weekly
    rotate 4
    compress
    delaycompress
    missingok
    notifempty
    copytruncate
    create 0644 kowen kowen
}
